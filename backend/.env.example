# Copy this file to .env and fill in real values. Never commit .env itself.

# MongoDB Atlas connection string (Database Access > your user > connection string)
MONGO_URI=

# Long random string used to sign login tokens. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# Credentials used ONCE by createAdmin.js to seed the first admin account.
# Use a strong password (12+ chars, mixed case/numbers/symbols).
ADMIN_EMAIL=
ADMIN_PASS=

PORT=

# Razorpay — https://dashboard.razorpay.com/app/keys (use rzp_test_ keys while developing)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Optional: Razorpay Dashboard > Webhooks > add https://YOUR_DOMAIN/api/payment/webhook
RAZORPAY_WEBHOOK_SECRET=
