MONGO_URI=
JWT_SECRET=
ADMIN_EMAIL=
ADMIN_PASS=
PORT=

# Razorpay — get these from https://dashboard.razorpay.com/app/keys
# Use the TEST MODE key pair while developing (starts with rzp_test_)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Optional but recommended: Razorpay Dashboard > Webhooks > add
# https://YOUR_BACKEND_DOMAIN/api/payment/webhook and set the same secret here
RAZORPAY_WEBHOOK_SECRET=

# ── Email (Nodemailer / SMTP) ──
# For Gmail: EMAIL_HOST=smtp.gmail.com, EMAIL_PORT=587, EMAIL_USER=your address,
# EMAIL_PASS=an App Password (myaccount.google.com/apppasswords) — NOT your normal password.
# Any other provider (Hostinger, Zoho, Outlook, etc.) works too — just use their SMTP details.
# EMAIL_HOST=
# EMAIL_PORT=
# EMAIL_USER=
# EMAIL_PASS=
# EMAIL_FROM=
BREVO_API_KEY=
EMAIL_FROM=
# Where new-order alerts are sent (defaults to ADMIN_EMAIL if left blank)
ADMIN_NOTIFY_EMAIL=

# ── WhatsApp business number for the "message us" order link ──
# Digits only, with country code, no + or spaces (e.g. 923001234567)
WHATSAPP_NUMBER=

# The URL where your fontend/index.html is actually served (used to build
# password-reset links). e.g. https://survan.com or http://127.0.0.1:5500
FRONTEND_URL=